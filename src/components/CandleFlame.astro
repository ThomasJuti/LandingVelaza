---
interface Props {
  width?: number;
}

const { width = 68 } = Astro.props;
---

<svg
  class="candle"
  width={width}
  height={width * 1.55}
  viewBox="0 0 60 93"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <radialGradient id="candle-glow" cx="50%" cy="42%" r="60%">
      <stop offset="0%" stop-color="#f6d9a0" stop-opacity=".55" />
      <stop offset="100%" stop-color="#f6d9a0" stop-opacity="0" />
    </radialGradient>
    <linearGradient id="candle-flame-outer" x1="0" y1="1" x2="0" y2="0">
      <stop offset="0%" stop-color="#c67c52" />
      <stop offset="55%" stop-color="#e8a15c" />
      <stop offset="100%" stop-color="#f6d9a0" />
    </linearGradient>
    <radialGradient id="candle-flame-inner" cx="50%" cy="78%" r="65%">
      <stop offset="0%" stop-color="#fff6df" />
      <stop offset="100%" stop-color="#f6d9a0" />
    </radialGradient>
  </defs>

  <circle cx="30" cy="38" r="34" fill="url(#candle-glow)" />

  <rect x="12" y="54" width="36" height="34" rx="6" fill="#fbf7ef" stroke="rgba(63,42,29,.12)" />
  <ellipse cx="30" cy="54" rx="18" ry="5" fill="#fdf9f0" />
  <line x1="30" y1="54" x2="30" y2="41" stroke="#3f2a1d" stroke-width="2" stroke-linecap="round" />

  <g class="flame-outer">
    <path
      d="M30 8 C22 21 16 31 16 40 C16 48 22.2 54 30 54 C37.8 54 44 48 44 40 C44 31 38 21 30 8 Z"
      fill="url(#candle-flame-outer)"
    />
  </g>
  <g class="flame-inner">
    <path
      d="M30 21 C26.2 28.5 24 34 24 38.5 C24 42.9 26.7 46 30 46 C33.3 46 36 42.9 36 38.5 C36 34 33.8 28.5 30 21 Z"
      fill="url(#candle-flame-inner)"
    />
  </g>
</svg>

<style>
  .candle {
    display: block;
    margin: 44px auto 0;
    overflow: visible;
  }
  .flame-outer,
  .flame-inner {
    transform-box: fill-box;
    transform-origin: 50% 100%;
  }
  .flame-outer {
    animation: flick-outer 2.6s ease-in-out infinite;
  }
  .flame-inner {
    animation: flick-inner 2.1s ease-in-out infinite;
  }
  @keyframes flick-outer {
    0%,
    100% {
      transform: scale(1, 1) rotate(-1.5deg);
    }
    50% {
      transform: scale(1.05, 1.08) rotate(1.5deg);
    }
  }
  @keyframes flick-inner {
    0%,
    100% {
      transform: scale(1, 1) rotate(1deg);
      opacity: 0.95;
    }
    50% {
      transform: scale(0.94, 1.06) rotate(-1.5deg);
      opacity: 1;
    }
  }
</style>
