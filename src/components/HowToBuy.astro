---
const PASOS = [
  { title: "Elige tus velas", desc: "Explora el catálogo y anota lo que te gusta." },
  { title: "Escríbenos", desc: "Mándanos tu pedido por WhatsApp con base en el catálogo." },
  { title: "Coordinamos", desc: "Acordamos pago y entrega. ¡Listo!" },
];
---

<section class="como-comprar" id="como-comprar">
  <h2>Cómo comprar</h2>
  <div class="steps">
    {
      PASOS.map((paso, i) => (
        <div class="step">
          <span class="step-num">{i + 1}</span>
          <div>
            <div class="step-title">{paso.title}</div>
            <div class="step-desc">{paso.desc}</div>
          </div>
        </div>
      ))
    }
  </div>
</section>
